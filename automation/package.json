{
  "dependencies": {
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "artillery": "^2.0.21",
    "dotenv": "^17.3.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "test:ui": "playwright test -c playwright.ui.config.ts",
    "test:ui:headed": "HEADLESS=false playwright test -c playwright.ui.config.ts",
    "test:report": "playwright show-report",
    "test:trace": "playwright show-trace",
    "test:api": "playwright test -c playwright.api.config.ts",
    "test:api:headed": "HEADLESS=false playwright test -c playwright.api.config.ts",
    "test:all": "npm run test:api && npm run test:ui"
  }
}
